{
  "name": "frontend-musfy",
  "private": true,
  "version": "0.1.25",
  "description": "MusFy desktop player with library sync, mini player, tray mode, video playback, and GitHub-powered updates",
  "author": "MusFy",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasbuen/MusFy.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node build/windows/prepare-runtime.cjs && tsc && vite build && electron-builder",
    "release:github": "node scripts/publish-github-release.cjs",
    "release:github:build-only": "node scripts/publish-github-release.cjs --build-only",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "verify": "npm run lint && npm run test && tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "axios": "^1.14.0",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "localforage": "^1.10.0",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.5"
  },
  "main": "dist-electron/main.js"
}
